{
  "name": "omnitron-dev",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build && turbo build:titan",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:down": "docker compose -f docker-compose.test.yml down -v",
    "test:ci": "docker compose -f docker-compose.test.yml up -d --wait && turbo test; docker compose -f docker-compose.test.yml down -v",
    "lint": "eslint \"{apps,packages}/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"{apps,packages}/**/*.{js,jsx,ts,tsx}\"",
    "lint:print": "eslint --print-config eslint.config.mjs > eslint-show-config.json",
    "fm:check": "prettier --check \"{apps,packages}/**/*.{js,jsx,ts,tsx}\"",
    "fm:fix": "prettier --write \"{apps,packages}/**/*.{js,jsx,ts,tsx}\"",
    "fix:all": "pnpm lint:fix && pnpm fm:fix",
    "cleanup": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +",
    "changeset": "changeset",
    "ai-prompt": "ts-node scripts/gen-aiprompt.ts",
    "publish": "ts-node scripts/publish.ts",
    "transform-hugeicons": "tsx scripts/transform-hugeicons.ts",
    "link:global": "cd apps/omnitron && pnpm link --global",
    "unlink:global": "pnpm uninstall --global @omnitron-dev/omnitron",
    "kb:extract": "turbo kb:extract",
    "kb:index": "cd apps/omnitron && tsx src/commands/kb.ts index"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@omnitron-dev/omnitron": "workspace:*",
    "@types/add": "^2.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.6.0",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@xec-sh/kit": "^0.9.0",
    "add": "^2.0.6",
    "eslint": "10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "semver": "^7.7.4",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  },
  "pnpm": {
    "overrides": {
      "web-worker": "1.5.0",
      "@typescript-eslint/eslint-plugin": "8.59.2",
      "@typescript-eslint/parser": "8.59.2",
      "@typescript-eslint/utils": "8.59.2",
      "@typescript-eslint/typescript-estree": "8.59.2",
      "@typescript-eslint/type-utils": "8.59.2",
      "@typescript-eslint/scope-manager": "8.59.2",
      "@typescript-eslint/visitor-keys": "8.59.2"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "cpu-features",
      "ssh2",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "systeminformation": "^5.31.5"
  }
}
