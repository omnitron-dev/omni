{
  "name": "@omnitron-dev/titan",
  "version": "0.1.0",
  "description": "Enterprise backend framework — core DI, Netron RPC, decorators, and validation",
  "keywords": [
    "backend",
    "framework",
    "server",
    "http",
    "rest",
    "websocket",
    "microservices",
    "dependency-injection",
    "DI"
  ],
  "author": "LuxQuant",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./application": {
      "types": "./dist/application/index.d.ts",
      "default": "./dist/application/index.js"
    },
    "./decorators": {
      "types": "./dist/decorators/index.d.ts",
      "default": "./dist/decorators/index.js"
    },
    "./netron": {
      "types": "./dist/netron/index.d.ts",
      "default": "./dist/netron/index.js"
    },
    "./netron/transport/http": {
      "types": "./dist/netron/transport/http/index.d.ts",
      "default": "./dist/netron/transport/http/index.js"
    },
    "./netron/transport/websocket": {
      "types": "./dist/netron/transport/websocket/index.d.ts",
      "default": "./dist/netron/transport/websocket/index.js"
    },
    "./netron/transport/tcp": {
      "types": "./dist/netron/transport/tcp-transport.d.ts",
      "default": "./dist/netron/transport/tcp-transport.js"
    },
    "./netron/transport/unix": {
      "types": "./dist/netron/transport/unix-transport.d.ts",
      "default": "./dist/netron/transport/unix-transport.js"
    },
    "./netron/transport/http/middleware": {
      "types": "./dist/netron/transport/http/middleware/index.d.ts",
      "import": "./dist/netron/transport/http/middleware/index.js",
      "default": "./dist/netron/transport/http/middleware/index.js"
    },
    "./netron/auth": {
      "types": "./dist/netron/auth/index.d.ts",
      "default": "./dist/netron/auth/index.js"
    },
    "./netron/multi-backend": {
      "types": "./dist/netron/multi-backend/index.d.ts",
      "default": "./dist/netron/multi-backend/index.js"
    },
    "./nexus": {
      "types": "./dist/nexus/index.d.ts",
      "default": "./dist/nexus/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    },
    "./module/config": {
      "types": "./dist/modules/config/index.d.ts",
      "default": "./dist/modules/config/index.js"
    },
    "./module/logger": {
      "types": "./dist/modules/logger/index.d.ts",
      "default": "./dist/modules/logger/index.js"
    },
    "./module/rls": {
      "types": "./dist/netron/auth/decorators.d.ts",
      "default": "./dist/netron/auth/decorators.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist node_modules/.tmp && tsc -p ./tsconfig.json",
    "test": "vitest run",
    "test:node": "vitest run",
    "test:bun": "/Users/taaliman/.bun/bin/bun test test/runtime/bun-all.test.ts",
    "test:deno": "/Users/taaliman/.deno/bin/deno test --no-check --allow-read --allow-write --allow-env --allow-sys --allow-net --unstable-sloppy-imports test/runtime/deno-all.test.ts",
    "test:all": "npm run test:node && npm run test:bun && npm run test:deno",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -p ./tsconfig.json --watch"
  },
  "dependencies": {
    "@kysera/rls": "^0.8.7",
    "@omnitron-dev/common": "workspace:*",
    "@omnitron-dev/eventemitter": "workspace:*",
    "@omnitron-dev/msgpack": "workspace:*",
    "glob": "^13.0.0",
    "ipaddr.js": "^2.3.0",
    "minimatch": "^10.1.1",
    "msgpackr": "^1.11.5",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "readable-stream": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.7.3",
    "ws": "^8.18.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.0"
  },
"devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@playwright/test": "^1.57.0",
    "@types/bun": "latest",
    "@types/node": "25.0.3",
    "@types/pino": "7.0.4",
    "@types/readable-stream": "^4.0.23",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "@vitest/runner": "^4.0.18",
    "http-server": "^14.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/omnitron-dev/omni.git",
    "directory": "packages/titan"
  }
}
