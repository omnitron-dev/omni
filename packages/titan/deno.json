{
  "compilerOptions": {
    "allowJs": true,
    "lib": ["deno.window", "deno.ns", "esnext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "moduleDetection": "force"
  },
  "imports": {
    "@omnitron-dev/eventemitter": "../eventemitter/dist/index.js",
    "@omnitron-dev/common": "../common/dist/index.js",
    "@omnitron-dev/msgpack": "../msgpack/dist/index.js",
    "@omnitron-dev/msgpack/smart-buffer": "../msgpack/dist/smart-buffer.js",
    "long": "npm:long@^5.3.2",
    "buffer": "npm:buffer@^6.0.3",
    "events": "node:events",
    "node:assert": "node:assert",
    "node:buffer": "node:buffer",
    "node:child_process": "node:child_process",
    "node:cluster": "node:cluster",
    "node:crypto": "node:crypto",
    "node:dgram": "node:dgram",
    "node:dns": "node:dns",
    "node:events": "node:events",
    "node:fs": "node:fs",
    "node:fs/promises": "node:fs/promises",
    "node:http": "node:http",
    "node:https": "node:https",
    "node:net": "node:net",
    "node:os": "node:os",
    "node:path": "node:path",
    "node:perf_hooks": "node:perf_hooks",
    "node:process": "node:process",
    "node:querystring": "node:querystring",
    "node:readline": "node:readline",
    "node:stream": "node:stream",
    "node:string_decoder": "node:string_decoder",
    "node:timers": "node:timers",
    "node:tls": "node:tls",
    "node:tty": "node:tty",
    "node:url": "node:url",
    "node:util": "node:util",
    "node:v8": "node:v8",
    "node:vm": "node:vm",
    "node:worker_threads": "node:worker_threads",
    "node:zlib": "node:zlib"
  },
  "tasks": {
    "test": "deno test --no-check --allow-read --allow-write --allow-env --allow-sys --allow-net test/runtime/deno-all.test.ts",
    "test:unstable": "deno test --no-check --allow-read --allow-write --allow-env --allow-sys --allow-net --unstable-sloppy-imports test/runtime/deno-all.test.ts"
  },
  "nodeModulesDir": "none",
  "unstable": ["sloppy-imports"]
}
