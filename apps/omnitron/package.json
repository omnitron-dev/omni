{
  "name": "@omnitron-dev/omnitron",
  "version": "0.1.1",
  "description": "Production-grade Titan application supervisor",
  "type": "module",
  "bin": {
    "omnitron": "./dist/cli/omnitron.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "default": "./dist/config/index.js"
    },
    "./dto/services": {
      "types": "./src/shared/dto/services.ts",
      "default": "./dist/shared/dto/services.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && pnpm build:webapp",
    "build:backend": "tsc -p tsconfig.build.json",
    "build:webapp": "cd webapp && npx vite build",
    "start": "node dist/cli/omnitron.js",
    "up": "node dist/cli/omnitron.js up",
    "down": "node dist/cli/omnitron.js down",
    "migrate": "tsx src/database/migrate.ts",
    "migrate:down": "tsx src/database/migrate.ts --down",
    "typecheck": "tsc --noEmit",
    "typecheck:webapp": "tsc --noEmit -p webapp/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@kysera/migrations": "^0.8.7",
    "@omnitron-dev/common": "workspace:*",
    "@omnitron-dev/eventemitter": "workspace:*",
    "@omnitron-dev/titan": "workspace:*",
    "@omnitron-dev/titan-auth": "workspace:*",
    "@omnitron-dev/titan-health": "workspace:*",
    "@omnitron-dev/titan-metrics": "workspace:*",
    "@omnitron-dev/titan-pm": "workspace:*",
    "@omnitron-dev/titan-scheduler": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "@omnitron-dev/kb": "workspace:*",
    "@omnitron-dev/titan-telemetry-relay": "workspace:*",
    "@xec-sh/core": "^0.9.0",
    "@xec-sh/kit": "^0.9.0",
    "@xec-sh/ops": "^0.9.0",
    "commander": "^14.0.3",
    "jose": "^6.0.11",
    "kysely": "0.28.12",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/pg": "^8.16.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "webapp/dist",
    "data"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omnitron-dev/omni",
    "directory": "apps/omnitron"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
