{
  "name": "@omnitron-dev/titan-telemetry-relay",
  "version": "0.1.0",
  "description": "Store-and-forward telemetry pipeline for distributed Titan applications",
  "author": "LuxQuant",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist node_modules/.tmp && tsc -p ./tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@omnitron-dev/eventemitter": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
