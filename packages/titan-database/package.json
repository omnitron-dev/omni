{
  "name": "@omnitron-dev/titan-database",
  "version": "0.1.3",
  "description": "Database module for Titan framework with Kysely, migrations, RLS, and multi-dialect support",
  "author": "LuxQuant",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugins": {
      "types": "./dist/exports/plugins.d.ts",
      "default": "./dist/exports/plugins.js"
    },
    "./transaction": {
      "types": "./dist/exports/transaction.d.ts",
      "default": "./dist/exports/transaction.js"
    },
    "./repository": {
      "types": "./dist/exports/repository.d.ts",
      "default": "./dist/exports/repository.js"
    },
    "./migration": {
      "types": "./dist/exports/migration.d.ts",
      "default": "./dist/exports/migration.js"
    },
    "./kysera": {
      "types": "./dist/exports/kysera.d.ts",
      "default": "./dist/exports/kysera.js"
    },
    "./rls": {
      "types": "./dist/exports/rls.d.ts",
      "default": "./dist/exports/rls.js"
    },
    "./dialects": {
      "types": "./dist/exports/dialects.d.ts",
      "default": "./dist/exports/dialects.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist node_modules/.tmp && tsc -p ./tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kysera/audit": "^0.8.8",
    "@kysera/core": "^0.8.8",
    "@kysera/dal": "^0.8.8",
    "@kysera/dialects": "^0.8.8",
    "@kysera/executor": "^0.8.8",
    "@kysera/infra": "^0.8.8",
    "@kysera/migrations": "^0.8.8",
    "@kysera/repository": "^0.8.8",
    "@kysera/rls": "^0.8.8",
    "@kysera/soft-delete": "^0.8.8",
    "@kysera/timestamps": "^0.8.8",
    "@omnitron-dev/eventemitter": "workspace:*",
    "kysely": "^0.28.15",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@omnitron-dev/titan": "workspace:*",
    "pg": "^8.20.0",
    "mysql2": "^3.20.0",
    "better-sqlite3": "^12.8.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "reflect-metadata": "^0.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
