{
  "name": "@omnitron-dev/netron-react",
  "version": "0.1.2",
  "description": "Production-grade React library for Netron RPC with type-safe hooks, real-time subscriptions, and unified state management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/hooks/index.d.ts",
        "default": "./dist/hooks/index.js"
      },
      "require": {
        "types": "./dist/hooks/index.d.cts",
        "default": "./dist/hooks/index.cjs"
      }
    },
    "./state": {
      "import": {
        "types": "./dist/state/index.d.ts",
        "default": "./dist/state/index.js"
      },
      "require": {
        "types": "./dist/state/index.d.cts",
        "default": "./dist/state/index.cjs"
      }
    },
    "./auth": {
      "import": {
        "types": "./dist/auth/index.d.ts",
        "default": "./dist/auth/index.js"
      },
      "require": {
        "types": "./dist/auth/index.d.cts",
        "default": "./dist/auth/index.cjs"
      }
    },
    "./cache": {
      "import": {
        "types": "./dist/cache/index.d.ts",
        "default": "./dist/cache/index.js"
      },
      "require": {
        "types": "./dist/cache/index.d.cts",
        "default": "./dist/cache/index.cjs"
      }
    },
    "./devtools": {
      "import": {
        "types": "./dist/devtools/index.d.ts",
        "default": "./dist/devtools/index.js"
      },
      "require": {
        "types": "./dist/devtools/index.d.cts",
        "default": "./dist/devtools/index.cjs"
      }
    },
    "./test": {
      "import": {
        "types": "./dist/test/index.d.ts",
        "default": "./dist/test/index.js"
      },
      "require": {
        "types": "./dist/test/index.d.cts",
        "default": "./dist/test/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:unit": "vitest run --exclude test/integration/**",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@omnitron-dev/netron-browser": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0 || >=19.0.0",
    "react-dom": ">=18.0.0 || >=19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "ws": "^8.18.3"
  },
  "keywords": [
    "react",
    "hooks",
    "rpc",
    "netron",
    "titan",
    "state-management",
    "real-time",
    "websocket",
    "typescript",
    "data-fetching",
    "cache"
  ],
  "author": "Omnitron Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omnitron-dev/omni.git",
    "directory": "packages/netron-react"
  },
  "bugs": {
    "url": "https://github.com/omnitron-dev/omni/issues"
  },
  "homepage": "https://github.com/omnitron-dev/omni/tree/main/packages/netron-react#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
