{
  "$schema": "https://v2-8-17.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ],
      "outputLogs": "new-only"
    },
    "build:titan": {
      "dependsOn": [
        "@omnitron-dev/titan#build",
        "@omnitron-dev/eventemitter#build",
        "@omnitron-dev/testing#build"
      ],
      "outputs": [
        "dist/titan/**"
      ],
      "outputLogs": "new-only"
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": [
        "^test"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "lint": {},
    "kb:extract": {
      "dependsOn": [
        "build"
      ],
      "inputs": [
        "src/**/*.ts",
        "kb/kb.config.ts"
      ],
      "outputs": [
        "kb/generated/**"
      ],
      "outputLogs": "new-only"
    }
  }
}