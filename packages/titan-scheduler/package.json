{
  "name": "@omnitron-dev/titan-scheduler",
  "version": "0.1.3",
  "description": "Cron, interval, and timeout job scheduling with persistence and metrics for Titan",
  "author": "LuxQuant",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "default": "./dist/persistence/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist node_modules/.tmp && tsc -p ./tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@omnitron-dev/eventemitter": "workspace:*",
    "node-cron": "^4.2.1"
  },
  "peerDependencies": {
    "@omnitron-dev/titan": "workspace:*",
    "kysely": "0.28.12"
  },
  "peerDependenciesMeta": {
    "kysely": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "25.0.3",
    "@types/node-cron": "^3.0.11",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
