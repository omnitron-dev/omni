{
  "name": "@omnitron-dev/titan-health",
  "version": "0.1.2",
  "description": "Health check module for Titan framework with extensible indicators",
  "author": "LuxQuant",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist node_modules/.tmp && tsc -p ./tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@omnitron-dev/titan": "workspace:*",
    "ioredis": "^5.8.2",
    "kysely": "0.28.12"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "kysely": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "25.0.3",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
